projection;
strict ( 2 );
use draft;

define behavior for ZC_BOOKING alias Booking
{
  use create;
  use update;
  use delete;

  use action Edit;
  use action Activate;
  use action Discard;
  use action Resume;
  use action Prepare;

  use action confirmBooking;
  use action cancelBooking;
  use action generateTicket;
  use action resetTicket;
}